print("             QUESTION NO.1 ATM MACHINE SYSTEM               ")
print("************************************************************")
print("                                                            ")
account_balance = int(input("Enter Your Account Balance : "))
withdraw_amount = int(input("Enter Your Withdraw Amount : "))
if (withdraw_amount > account_balance):
    print("Insuffient Balance")
if (withdraw_amount < 500):
    print("Minimum Withdrawal Is 500")
else:
    deduct = account_balance - withdraw_amount  
    print("Your Remaining Balance : ",deduct)
if (account_balance > 10000):    
    print("Premium User")
else:
    print("Normal User")
print(                                                              )
print("************************************************************")
print("          QUESTION NO.2 SMART USERNAME VALIDATOR            ")
print("************************************************************")
username = input("Enter Your Username : ")    
lenght = len(username)
if (lenght <= 8):
    print("ERROR!, Username length must be greater than or equal to 8")
    
elif (" " in username):
    print("ERROR!, Username should not contain spaces")
    
elif not username[0].isupper():
    print("ERROR!, Username must start with a capital letter")
    
elif not any(char.isdigit() for char in username):
    print("ERROR!, Username must contain at least one number")
else:   
    print("Successfully! Your username is perfectly correct")    
print("                                                                  ") 
