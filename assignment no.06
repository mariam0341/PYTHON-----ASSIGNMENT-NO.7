print("          QUESTION NO.5 ONLINE SHOPPING DISCOUNT SYSTEM              ")
print("*********************************************************************")
print("                                                                     ")
customer_name = input("Enter Your Name : ")
total_bill = int(input("Enter Your Total Bill : "))
membership_status = input("Do you have Membership? {Yes or No} ").lower()

if (total_bill > 5000 and membership_status == "yes"):
    print("Congratulations! You got a 20% discount")
    discount = total_bill * 0.20
    final_bill = total_bill - discount
    
elif (total_bill > 3000):
    print("Congratulations! You got a 10% discount")
    discount = total_bill * 0.10 
    final_bill = total_bill - discount
    
else:
    discount = 0
    final_bill = total_bill
    print("No discount applied.")

print("Discount Amount:", discount)
print("Final Bill to pay:", final_bill)
