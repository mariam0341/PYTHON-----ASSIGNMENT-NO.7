print("            QUESTION NO.4 PASSWORD SECURITY CHECKER              ")    
print("*****************************************************************")    
print("                                                                 ")    
password = input("Enter Your Password : ")
lenght = len(password)
if (lenght <= 8):
    print("ERROR! Password lenght should be greater than or equal to 8")
    
elif ("@" not in password or "#" not in password):
    print("ERROR! Password must contain '@' or '#'")
    
elif (" " in password):
    print("ERROR! Password should not contain spaces")
    
elif not password[0].isupper():  
    print("ERROR!First character should be uppercase")
    
else:    
    print("Strong Password")   
print(                                                                       )
