print("                QUESTION NO.7 SMART NUMBER ANALYZER                  ")
print("*********************************************************************")
print("                                                                     ")
num = int(input("Enter Your Number : "))
if num > 0:
    print("Positive Number")
elif num < 0:
    print("Negative Number")
else:
    print("The number is Zero")

if num % 2 == 0:
    print("Even Number")
else:
    print("Odd Number")

if num % 5 == 0:
    print("Divisible by 5")
else:
    print("Not divisible by 5")

if num > 100:
    print("Large Number")
