print("            QUESTION NO.3 EXAM ELIGIBILITY CHECKER                ")
print("******************************************************************")
print("                                                                 ")    
username = input("Enter Your Name : ")
attendance_percentage = int(input("Enter Your Attendance Percentage : "))
fees_status = input("Enter Your Fees Status : ").lower()
attendance_status = attendance_percentage >= 75
fees_status = "paid"
if (attendance_status and fees_status == "paid"):
